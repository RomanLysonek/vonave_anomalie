{
  "schema_version": "c34-screening-v1",
  "screening_policy": {
    "origins": [
      "2023-01-10",
      "2024-06-20",
      "2024-11-29",
      "2025-02-10"
    ],
    "epochs": 12,
    "seed": 42,
    "batch_size": 2048,
    "strategy": "direct",
    "structured_models_during_nn_screen": [],
    "identical_nn_configurations_reused_in_memory": true,
    "tree_modes_evaluated_separately": [
      "log1p",
      "residual",
      "tweedie"
    ],
    "quality_tolerance": 0.03,
    "min_relative_improvement": 0.002
  },
  "c2_base": {
    "feature_groups": [
      "price",
      "campaign",
      "lifecycle",
      "market",
      "event"
    ],
    "screened_half_lives": [
      null,
      365.0
    ],
    "selected_half_life": null
  },
  "stage_winners": {
    "c2_gate": "base_half_none",
    "nn_loss": "loss_mse",
    "nn_target": "target_residual",
    "channel_aux": "channel_control",
    "final_sensitivity": "final_half_none",
    "xgboost_target_mode": "residual",
    "lightgbm_target_mode": "log1p"
  },
  "recommendation": {
    "candidate": "final_half_none",
    "config": {
      "nn_loss": "mse",
      "nn_target_mode": "residual",
      "nn_combined_mse_weight": 0.25,
      "enable_channel_history_features": false,
      "channel_aux_weight": 0.0,
      "channel_share_smoothing": 0.5,
      "tree_target_mode": "log1p",
      "xgboost_target_mode": "residual",
      "lightgbm_target_mode": "log1p"
    },
    "recency_half_life_days": null,
    "c2_feature_groups": [
      "price",
      "campaign",
      "lifecycle",
      "market",
      "event"
    ],
    "full_confirmation_command": "caffeinate -i uv run python ml/pipeline.py --forecast-strategy direct --primary-strategy direct --submission-model NeuralNet --selection-metric WAPE --selection-protocol test-aligned --training-window-days all --recency-half-life-days none --baseline-variant weighted_4321 --trend-features off --c2-feature-groups price,campaign,lifecycle,market,event --c34-config outputs/c34_screening/recommendation.json --nn-batch-size 512 --nn-lr-scaling fixed --reset-checkpoints 2>&1 | tee pipeline_c34_direct_512_fixed.log",
    "full_confirmation_resume_command": "caffeinate -i uv run python ml/pipeline.py --forecast-strategy direct --primary-strategy direct --submission-model NeuralNet --selection-metric WAPE --selection-protocol test-aligned --training-window-days all --recency-half-life-days none --baseline-variant weighted_4321 --trend-features off --c2-feature-groups price,campaign,lifecycle,market,event --c34-config outputs/c34_screening/recommendation.json --nn-batch-size 512 --nn-lr-scaling fixed --resume 2>&1 | tee -a pipeline_c34_direct_512_fixed.log"
  },
  "base_config": {
    "train_path": "data/train_data.parquet",
    "test_path": "data/test_data.parquet",
    "output_dir": "outputs",
    "horizon": 7,
    "lag_windows": [
      7,
      14,
      28
    ],
    "num_products": 30,
    "embed_dim_product": 12,
    "embed_dim_campaign": 4,
    "embed_dim_horizon": 4,
    "hidden_dims": [
      256,
      128,
      64
    ],
    "dropout": [
      0.2,
      0.15,
      0.1
    ],
    "lr": 0.001,
    "weight_decay": 0.0001,
    "batch_size": 2048,
    "reference_batch_size": 512,
    "nn_lr_scaling": "fixed",
    "nn_training_backend": "auto",
    "cv_epochs": 12,
    "final_epochs": 12,
    "seeds": [
      42
    ],
    "n_cv_folds": 4,
    "seed": 42,
    "ridge_alpha": 10.0,
    "ridge_prediction_cap": null,
    "nn_residual_guard_lower_quantile": 0.001,
    "nn_residual_guard_upper_quantile": 0.999,
    "nn_residual_guard_margin": 1.0,
    "recursive_safety_multiplier": 50.0,
    "recursive_safety_floor": 10000.0,
    "training_window_days": null,
    "recency_half_life_days": null,
    "baseline_variant": "weighted_4321",
    "enable_trend_features": false,
    "c2_feature_groups": [
      "price",
      "campaign",
      "lifecycle",
      "market",
      "event"
    ],
    "nn_loss": "huber",
    "nn_target_mode": "residual",
    "nn_huber_delta": 1.0,
    "nn_combined_mse_weight": 0.25,
    "tree_target_mode": "log1p",
    "xgboost_target_mode": null,
    "lightgbm_target_mode": null,
    "tree_tweedie_variance_power": 1.5,
    "enable_channel_history_features": false,
    "channel_aux_weight": 0.0,
    "channel_share_smoothing": 0.5
  }
}